{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "process:allow-exit",
    "shell:allow-execute",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "name": "binaries/makerom",
          "sidecar": true
        },
        {
          "args": true,
          "name": "binaries/ctrdecrypt",
          "sidecar": true
        },
        {
          "args": true,
          "name": "binaries/3dstool",
          "sidecar": true
        },
        {
          "args": true,
          "name": "binaries/ctrtool",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**/*" }]
    },
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-read-file",
    "fs:allow-write-file"
  ]
}