{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ciavc-patch-tool",
  "version": "0.1.0",
  "identifier": "com.tom.ciavc-patch-tool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ciavc-patch-tool",
        "width": 800,
        "height": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
      "externalBin": [
        "binaries/makerom",
        "binaries/ctrdecrypt",
        "binaries/3dstool",
        "binaries/ctrtool"
      ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "Makerom CLI Tool",
      "args": [
        {
          "name": "cia",
          "index": 1,
          "takesValue": true,
          "description": "CIA file path"
        },
        {
          "name": "save",
          "index": 2,
          "takesValue": true,
          "description": "Save file path"
        },
        {
          "name": "patch",
          "short": "p",
          "takesValue": true,
          "description": "Patch file path"
        },
        {
          "name": "rom",
          "short": "r",
          "takesValue": true,
          "description": "ROM file path"
        },
        {
          "name": "gen2patch",
          "short": "g",
          "takesValue": false,
          "description": "Patch Gen2 Code"
        },
        {
          "name": "iskorean",
          "short": "k",
          "takesValue": false,
          "description": "Is Korean VC"
        }
      ]
    }
  }
}
